generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Organization {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  logoUrl       String?
  type          String?
  status        OrgStatus    @default(REGISTERED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  users         User[]
  schoolSettings SchoolSettings?
  classes       Class[]
  students      Student[]
  staff         Staff[]
  feeCategories FeeCategory[]
  feeStructures FeeStructure[]
  feePayments   FeePayment[]
  expenseCategories ExpenseCategory[]
  expenses      Expense[]
  exams         Exam[]
  results       Result[]
  subjects      Subject[]
  attendances   Attendance[]
  timetables    Timetable[]
  homeworks     Homework[]
  studyMaterials StudyMaterial[]
  announcements Announcement[]
  certificates  Certificate[]
  idCards       IDCard[]
  transports    TransportAssignment[]
  subscriptions Subscription[]
  saasPayments  SaasPayment[]
  usage         TenantUsage?
  supportTickets SupportTicket[]

  @@index([slug])
  @@index([status])
}

model Plan {
  id            String       @id @default(cuid())
  name          String       @unique
  code          String       @unique
  description   String?
  priceMonthly  Int          @default(0)
  priceYearly   Int          @default(0)
  maxStudents   Int          @default(50)
  maxStaff      Int          @default(5)
  maxBranches   Int          @default(1)
  maxAdminUsers Int          @default(1)
  storageGB     Int          @default(1)
  pdfDownloads  Int          @default(20)
  features      Json         @default("[]")
  isActive      Boolean      @default(true)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  subscriptions Subscription[]
  @@index([isActive])
  @@index([sortOrder])
}

model Subscription {
  id              String           @id @default(cuid())
  organizationId  String           @unique
  planId          String
  status          SubscriptionStatus @default(TRIALING)
  billingCycle    BillingCycle     @default(MONTHLY)
  trialEndsAt     DateTime?
  currentPeriodStart DateTime       @default(now())
  currentPeriodEnd   DateTime
  cancelledAt     DateTime?
  graceEndsAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan            Plan             @relation(fields: [planId], references: [id])
  payments        SaasPayment[]

  @@index([organizationId])
  @@index([planId])
  @@index([status])
}

model SaasPayment {
  id              String           @id @default(cuid())
  subscriptionId  String
  organizationId  String
  amount          Int
  currency        String           @default("INR")
  status          PaymentStatus    @default(CREATED)
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?
  invoiceNo       String?
  paymentMethod   String?
  paidAt          DateTime?
  createdAt       DateTime         @default(now())

  subscription    Subscription     @relation(fields: [subscriptionId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id])

  @@index([subscriptionId])
  @@index([organizationId])
  @@index([razorpayOrderId])
}

model TenantUsage {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  studentCount    Int          @default(0)
  staffCount      Int          @default(0)
  classCount      Int          @default(0)
  pdfDownloads    Int          @default(0)
  storageUsed     Int          @default(0)
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id              String       @id @default(cuid())
  provider        String       @default("razorpay")
  eventType       String
  payload         Json
  processed       Boolean      @default(false)
  processedAt     DateTime?
  error           String?
  createdAt       DateTime     @default(now())

  @@index([eventType])
  @@index([processed])
}

model SupportTicket {
  id              String           @id @default(cuid())
  organizationId  String
  subject         String
  description     String
  status          TicketStatus     @default(OPEN)
  priority        TicketPriority   @default(MEDIUM)
  createdById     String
  assignedToId    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  createdBy       User             @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo      User?            @relation("TicketAssignee", fields: [assignedToId], references: [id])
  replies         TicketReply[]

  @@index([organizationId])
  @@index([status])
  @@index([priority])
}

model TicketReply {
  id              String       @id @default(cuid())
  ticketId        String
  message         String
  userId          String
  isInternal      Boolean      @default(false)
  createdAt       DateTime     @default(now())

  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model User {
  id            String         @id @default(cuid())
  organizationId String?
  email         String         @unique
  passwordHash  String?
  name          String
  role          Role
  phone         String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  image         String?
  emailVerified DateTime?
  adharNo       String         @unique
  lastLogin     DateTime?
  isActive      Boolean        @default(true)
  isSuperAdmin  Boolean        @default(false)
  accounts      Account[]
  announcements Announcement[]
  AuditLog      AuditLog[]
  expenses      Expense[]
  notifications Notification[]
  sessions      Session[]
  staff         Staff?
  student       Student?
  exam          Exam[]     @relation("ExamCreatedBy")
  results       Result[]
  organization  Organization?  @relation(fields: [organizationId], references: [id])
  supportTickets SupportTicket[] @relation("TicketCreator")
  assignedTickets SupportTicket[] @relation("TicketAssignee")
  ticketReplies TicketReply[]

  @@index([role])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SchoolSettings {
  id           String           @id @default(cuid())
  organizationId String          @unique
  name         String
  address      String?
  contactEmail String?
  contactPhone String?
  academicYear String?
  logoUrl      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  faviconUrl   String?
  featureFlags Json?
  primaryColor String?
  galleryImages Json?
  heroImages   Json?
  principalName String?
  registrationNo String?
  receiptPrefix String?
  admissionPrefix String?
  staffIdPrefix String?
  gradingSystem String?
  dateFormat   String?
  currency     String?
  website      String?
  pdfHeader    String?
  pdfFooter    String?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  classes   Class[]
}

model Class {
  id            String         @id @default(cuid())
  organizationId String
  name          String
  grade         Grade
  section       String?
  gradeCode     String?
  teacherId     String?
  academicSessionId  String
  createdAt     DateTime       @default(now())
  academicSession    AcademicSession  @relation(fields: [academicSessionId], references: [id])
  attendances   Attendance[]
  teacher       Staff?         @relation("ClassTeacher", fields: [teacherId], references: [id])
  exams         Exam[]
  feeStructures FeeStructure[]
  students      Student[]
  subjects      Subject[]
  dateSheet     ExamDateSheet[]
  homeworks     Homework[]
  studyMaterials StudyMaterial[]
  timetables    Timetable[]
  organization  Organization @relation(fields: [organizationId], references: [id])

  @@index([teacherId])
  @@index([grade, section])
  @@index([organizationId])
}

model Subject {
  id           String       @id @default(cuid())
  organizationId String
  name         String
  code         String       @unique
  classId      String?
  teacherId    String?
  maxMarks     Float?
  passingMarks Float?
  type         SubjectType?
  results      Result[]
  class        Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher      Staff?       @relation(fields: [teacherId], references: [id])
  dateSheet    ExamDateSheet[]
  homeworks    Homework[]
  studyMaterials StudyMaterial[]
  timetables   Timetable[]
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([classId])
  @@index([teacherId])
  @@index([organizationId])
}

model Staff {
  id            String          @id @default(cuid())
  organizationId String
  userId        String          @unique
  staffId       String?
  designation   String
  department    String?
  qualification String?
  experience    String?
  salary        Float?
  joinDate      DateTime        @default(now())
  active        Boolean         @default(true)
  profileImg    String?
  gender        Gender?
  dob           DateTime?
  address       String?
  phone         String?
  Attendance    Attendance[]
  classes       Class[]         @relation("ClassTeacher")
  leaves        Leave[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization    @relation(fields: [organizationId], references: [id])
  subjects      Subject[]
  staffAttendance StaffAttendance[]
  documents     StaffDocument[]
  homework      Homework[]
  studyMaterials StudyMaterial[]
  timetables    Timetable[]
  certificates  Certificate[]
  idCards       IDCard[]

  @@index([userId])
  @@index([designation])
  @@index([staffId])
  @@index([organizationId])
}

model StaffDocument {
  id        String   @id @default(cuid())
  staffId   String
  type      String
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model StaffAttendance {
  id        String           @id @default(cuid())
  staffId   String
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([staffId, date])
}

model Student {
  id            String         @id @default(cuid())
  organizationId String
  userId        String         @unique
  admissionNo   String         @unique
  rollNumber    String
  admissionDate DateTime       @default(now())
  dob           DateTime?
  gender        Gender?
  bloodGroup    String?
  address       String?
  permanentAddress String?
  classId       String?
  active        Boolean        @default(true)
  profileImg    String?
  fatherName    String?
  fatherPhone   String?
  fatherOccupation String?
  motherName    String?
  motherPhone   String?
  motherOccupation String?
  guardianName  String?
  guardianPhone String?
  occupation    String         @default("")
  religion      String         @default("")
  caste         String         @default("")
  category      String?
  udiseCode     String?        @unique
  contactNo     String?
  previousSchool String?
  remarks       String?
  usesTransport Boolean        @default(false)
  attendance    Attendance[]
  fees          FeePayment[]
  results       Result[]
  transport     TransportAssignment[]
  class         Class?         @relation(fields: [classId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  Organization   @relation(fields: [organizationId], references: [id])
  notifications Notification[] @relation("NotificationToStudent")
  documents     StudentDocument[]
  homeworkSubmissions HomeworkSubmission[]
  certificates  Certificate[]
  idCards       IDCard[]

  @@unique([classId, rollNumber])
  @@index([classId])
  @@index([active])
  @@index([organizationId])
}

model StudentDocument {
  id        String   @id @default(cuid())
  studentId String
  type      String
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model TransportAssignment {
  id        String   @id @default(cuid())
  organizationId String
  studentId String   @unique
  routeName String?
  stopName  String?
  busNumber String?
  driverName String?
  driverPhone String?
  feeAmount Decimal? @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([studentId])
  @@index([isActive])
  @@index([organizationId])
}

model Attendance {
  id         String           @id @default(cuid())
  organizationId String
  classId    String
  studentId  String
  date       DateTime
  status     AttendanceStatus
  markedById String
  createdAt  DateTime         @default(now())
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedBy   Staff            @relation(fields: [markedById], references: [id])
  student           Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization      Organization     @relation(fields: [organizationId], references: [id])

  @@unique([studentId, date])
  @@index([classId, date])
  @@index([markedById])
}

model FeeCategory {
  id        String   @id @default(cuid())
  organizationId String
  name      String
  description String?
  createdAt DateTime @default(now())
  structures FeeStructure[]
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([name])
  @@index([organizationId])
}

model FeeStructure {
  id           String       @id @default(cuid())
  organizationId String
  classId      String
  categoryId   String?
  name         String?
  amount       Decimal      @default(0) @db.Decimal(12, 2)
  tuitionFee   Decimal?     @db.Decimal(12, 2)
  examFee      Decimal?     @db.Decimal(12, 2)
  transportFee Decimal?     @db.Decimal(12, 2)
  miscFee      Decimal?     @db.Decimal(12, 2)
  total        Decimal      @default(0) @db.Decimal(12, 2)
  monthlyFee   Decimal?     @db.Decimal(12, 2)
  totalMonths  Int          @default(12)
  isOptional   Boolean      @default(false)
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  payments     FeePayment[]
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  category     FeeCategory? @relation(fields: [categoryId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([classId])
  @@index([categoryId])
  @@index([organizationId])
}

model FeePayment {
  id                String       @id @default(cuid())
  organizationId    String
  studentId         String
  feeStructureId    String
  monthlyFee        Decimal?     @db.Decimal(12, 2)
  amountPaid        Decimal      @db.Decimal(12, 2)
  remainAmount      Decimal      @db.Decimal(12, 2)
  status            FeeStatus    @default(PENDING)
  paymentDate       DateTime?
  paymentMode       PaymentMethod?
  discount          Decimal?     @db.Decimal(12, 2)
  lateFine          Decimal?     @db.Decimal(12, 2)
  receiptNo         String?
  remarks           String?
  feeMonth          Int?
  razorpayOrder     String?      @unique
  razorpayPaymentId String?
  receiptUrl        String?
  createdAt         DateTime     @default(now())
  feeStructure      FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization      Organization @relation(fields: [organizationId], references: [id])

  @@index([studentId])
  @@index([feeStructureId])
  @@index([receiptNo])
  @@index([organizationId])
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  organizationId String
  name      String
  description String?
  createdAt DateTime @default(now())
  expenses  Expense[]
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([name])
  @@index([organizationId])
}

model Expense {
  id          String          @id @default(cuid())
  organizationId String
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  categoryId  String?
  paidTo      String?
  paymentMode PaymentMethod?
  billUrl     String?
  createdById String
  transaction TransactionType
  createdBy   User            @relation(fields: [createdById], references: [id])
  category    ExpenseCategory? @relation(fields: [categoryId], references: [id])
  organization Organization    @relation(fields: [organizationId], references: [id])

  @@index([createdById])
  @@index([categoryId])
  @@index([date])
  @@index([organizationId])
}

model Exam {
  id          String        @id @default(cuid())
  organizationId String
  name        String
  category    ExamCategory
  sequence    Int?
  classId     String
  startDate   DateTime
  endDate     DateTime
  isLocked    Boolean       @default(false)
  description String?
  instructions String?
  createdById String
  createdAt   DateTime      @default(now())

  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("ExamCreatedBy", fields: [createdById], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  results     Result[]
  dateSheet   ExamDateSheet[]

  @@index([classId])
  @@index([category])
  @@unique([classId, category, sequence])
  @@index([organizationId])
}

model ExamDateSheet {
  id        String   @id @default(cuid())
  examId    String
  classId   String
  subjectId String
  examDate  DateTime
  startTime DateTime
  endTime   DateTime
  room      String?

  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([classId])
  @@index([subjectId])
  @@unique([examId, subjectId, classId])
}

model Result {
  id         String   @id @default(cuid())
  organizationId String
  studentId  String
  examId     String
  subjectId  String
  marks      Float
  maxMarks   Float
  grade      String?
  rank       Int?
  remarks    String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader   User?    @relation(fields: [uploadedBy], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([studentId, examId, subjectId])
  @@index([studentId])
  @@index([examId])
  @@index([subjectId])
  @@index([organizationId])
}

model Timetable {
  id        String   @id @default(cuid())
  organizationId String
  classId   String
  subjectId String
  teacherId String?
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?
  createdAt DateTime @default(now())

  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Staff?   @relation(fields: [teacherId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([classId, dayOfWeek])
  @@index([teacherId])
  @@index([organizationId])
}

model Homework {
  id          String   @id @default(cuid())
  organizationId String
  classId     String
  subjectId   String
  teacherId   String
  title       String
  description String?
  dueDate     DateTime
  attachment  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     Staff    @relation(fields: [teacherId], references: [id])
  submissions HomeworkSubmission[]
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([classId])
  @@index([teacherId])
  @@index([organizationId])
}

model HomeworkSubmission {
  id         String   @id @default(cuid())
  homeworkId String
  studentId  String
  answerFile String?
  remarks    String?
  status     SubmissionStatus @default(PENDING)
  submittedAt DateTime @default(now())
  gradedAt   DateTime?
  teacherRemarks String?

  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
  @@index([studentId])
}

model StudyMaterial {
  id          String   @id @default(cuid())
  organizationId String
  classId     String
  subjectId   String
  teacherId   String
  title       String
  description String?
  fileUrl     String?
  videoLink   String?
  type        MaterialType
  createdAt   DateTime @default(now())

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     Staff    @relation(fields: [teacherId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([classId, subjectId])
  @@index([teacherId])
  @@index([organizationId])
}

model Announcement {
  id           String                   @id @default(cuid())
  organizationId String
  title        String
  content      String
  attachment   String?
  expiryDate   DateTime?
  isPinned     Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  createdBy    String
  creator      User                     @relation(fields: [createdBy], references: [id])
  organization Organization            @relation(fields: [organizationId], references: [id])
  visibleRoles AnnouncementVisibility[]

  @@index([organizationId])
}

model AnnouncementVisibility {
  id             String       @id @default(cuid())
  announcementId String
  role           Role
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, role])
  @@index([announcementId])
}

model Certificate {
  id             String   @id @default(cuid())
  organizationId String
  certificateNo  String   @unique
  type           CertificateType
  studentId      String?
  staffId        String?
  issueDate      DateTime @default(now())
  content        Json?
  remarks        String?
  createdAt      DateTime @default(now())

  student        Student? @relation(fields: [studentId], references: [id])
  staff          Staff?   @relation(fields: [staffId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([type])
  @@index([studentId])
  @@index([staffId])
  @@index([organizationId])
}

model IDCard {
  id        String   @id @default(cuid())
  organizationId String
  studentId String?  @unique
  staffId   String?  @unique
  cardNo    String   @unique
  issueDate DateTime @default(now())
  expiryDate DateTime?
  qrData    String?
  createdAt DateTime @default(now())

  student   Student? @relation(fields: [studentId], references: [id])
  staff     Staff?   @relation(fields: [staffId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([cardNo])
  @@index([organizationId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  Student   Student[]        @relation("NotificationToStudent")

  @@index([userId])
  @@index([type])
}

model Leave {
  id        String   @id @default(cuid())
  staffId   String
  fromDate  DateTime
  toDate    DateTime
  reason    String
  createdAt DateTime @default(now())
  status    String   @default("PENDING")
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}


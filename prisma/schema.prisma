generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
 
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  name          String
  role          Role
  phone         String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  image         String?
  emailVerified DateTime?
  adharNo       String         @unique
  accounts      Account[]
  announcements Announcement[]
  AuditLog      AuditLog[]
  expenses      Expense[]
  notifications Notification[]
  sessions      Session[]
  staff         Staff?
  student       Student?

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SchoolSettings {
  id           String           @id @default(cuid())
  name         String
  address      String?
  contactEmail String?
  contactPhone String?
  academicYear String?
  logoUrl      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  faviconUrl   String?
  featureFlags Json?
  primaryColor String?
  tier         SubscriptionTier @default(BASIC)
}

model Class {
  id            String         @id @default(cuid())
  name          String
  grade         Grade
  section       String?
  gradeCode     String?
  teacherId     String?
  createdAt     DateTime       @default(now())
  attendances   Attendance[]
  teacher       Staff?         @relation("ClassTeacher", fields: [teacherId], references: [id])
  exams         Exam[]
  feeStructures FeeStructure[]
  students      Student[]
  subjects      Subject[]

  @@index([teacherId])
  @@index([grade, section])
}

model Subject {
  id        String   @id @default(cuid())
  name     String
  code      String   @unique
  classId   String
  teacherId String?
  results   Result[]
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   Staff?   @relation(fields: [teacherId], references: [id])

  @@index([classId])
  @@index([teacherId])
}

model Staff {
  id          String       @id @default(cuid())
  userId      String       @unique
  designation String
  salary      Float?
  joinDate    DateTime     @default(now())
  active      Boolean      @default(true)
  Attendance  Attendance[]
  classes     Class[]      @relation("ClassTeacher")
  exams       Exam[]       @relation("ExamCreatedBy")
  leaves      Leave[]
  results     Result[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects    Subject[]

  @@index([userId])
  @@index([designation])
}

model Student {
  id            String         @id @default(cuid())
  userId        String         @unique
  admissionNo   String         @unique
  rollNumber    String
  admissionDate DateTime       @default(now())
  dob           DateTime?
  gender        Gender?
  address       String?
  classId       String?
  active        Boolean        @default(true)
  profileImg    String?
  fatherName    String?
  motherName    String?
  occupation    String         @default("")
  religion      String         @default("")
  caste         String         @default("")
  udiseCode     String?        @unique
  contactNo     String?
  attendance    Attendance[]
  fees          FeePayment[]
  results       Result[]
  class         Class?         @relation(fields: [classId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[] @relation("NotificationToStudent")

  @@unique([classId, rollNumber])
  @@index([classId])
  @@index([active])
}

model Attendance {
  id         String           @id @default(cuid())
  classId    String
  studentId  String
  date       DateTime
  status     AttendanceStatus
  markedById String
  createdAt  DateTime         @default(now())
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedBy   Staff            @relation(fields: [markedById], references: [id])
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([classId, date])
  @@index([markedById])
}

model FeeStructure {
  id           String       @id @default(cuid())
  classId      String
  name         String?
  tuitionFee   Decimal      @db.Decimal(12, 2)
  examFee      Decimal?     @db.Decimal(12, 2)
  transportFee Decimal?     @db.Decimal(12, 2)
  miscFee      Decimal?     @db.Decimal(12, 2)
  total        Decimal      @db.Decimal(12, 2)
  createdAt    DateTime     @default(now())
  payments     FeePayment[]
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
}

model FeePayment {
  id                String       @id @default(cuid())
  studentId         String
  feeStructureId    String
  amountPaid        Decimal      @db.Decimal(12, 2)
  remainAmount   Decimal      @db.Decimal(12,2)
  status            FeeStatus    @default(PENDING)
  paymentDate       DateTime?
  razorpayOrder     String?      @unique
  razorpayPaymentId String?
  receiptUrl        String?
  createdAt         DateTime     @default(now())
  feeStructure      FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([feeStructureId])
}

model Exam {
  id          String   @id @default(cuid())
  name        String
  classId     String
  startDate   DateTime
  endDate     DateTime
  createdById String
  createdAt   DateTime @default(now())
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy   Staff    @relation("ExamCreatedBy", fields: [createdById], references: [id])
  results     Result[]

  @@index([classId])
  @@index([createdById])
}

model Result {
  id         String   @id @default(cuid())
  studentId  String
  examId     String
  subjectId  String
  marks      Float
  maxMarks   Float
  grade      String?
  remarks    String?
  uploadedBy String?
  createdAt  DateTime @default(now())
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader   Staff?   @relation(fields: [uploadedBy], references: [id])

  @@index([studentId])
  @@index([examId])
  @@index([subjectId])
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  createdById String
  transaction TransactionType
  createdBy   User            @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model Announcement {
  id           String                   @id @default(cuid())
  title        String
  content      String
  createdAt    DateTime                 @default(now())
  createdBy    String
  creator      User                     @relation(fields: [createdBy], references: [id])
  visibleRoles AnnouncementVisibility[]
}

model AnnouncementVisibility {
  id             String       @id @default(cuid())
  announcementId String
  role           Role
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, role])
  @@index([announcementId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  Student   Student[]        @relation("NotificationToStudent")

  @@index([userId])
  @@index([type])
}

model Leave {
  id        String   @id @default(cuid())
  staffId   String
  fromDate  DateTime
  toDate    DateTime
  reason    String
  createdAt DateTime @default(now())
  status    String   @default("PENDING")
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
}

enum Role {
  ADMIN
  STAFF
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum NotificationType {
  ANNOUNCEMENT
  FEE_REMINDER
  RESULT_PUBLISHED
  ATTENDANCE_ALERT
  GENERAL
}

enum Grade {
  NURSERY
  LKG
  UKG
  ONE
  TWO
  THREE
  FOUR
  FIVE
  SIX
  SEVEN
  EIGHT
  NINE
  TEN
}

enum PaymentMethod {
  CASH
  ONLINE
  CARD
  UPI
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}


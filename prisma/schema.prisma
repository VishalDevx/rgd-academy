generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  name          String
  role          Role
  phone         String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  image         String?
  emailVerified DateTime?
  adharNo       String         @unique
  lastLogin     DateTime?
  isActive      Boolean        @default(true)
  accounts      Account[]
  announcements Announcement[]
  AuditLog      AuditLog[]
  expenses      Expense[]
  notifications Notification[]
  sessions      Session[]
  staff         Staff?
  student       Student?
  exam          Exam[]     @relation("ExamCreatedBy")
  results       Result[]
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SchoolSettings {
  id           String           @id @default(cuid())
  name         String
  address      String?
  contactEmail String?
  contactPhone String?
  academicYear String?
  logoUrl      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  faviconUrl   String?
  featureFlags Json?
  primaryColor String?
  tier         SubscriptionTier @default(BASIC)
  galleryImages Json?
  heroImages   Json?
  principalName String?
  registrationNo String?
  receiptPrefix String?
  admissionPrefix String?
  staffIdPrefix String?
  gradingSystem String?
  dateFormat   String?
  currency     String?
  website      String?
  pdfHeader    String?
  pdfFooter    String?
}

model AcademicSession {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  classes   Class[]
}

model Class {
  id            String         @id @default(cuid())
  name          String
  grade         Grade
  section       String?
  gradeCode     String?
  teacherId     String?
  academicSessionId  String
  createdAt     DateTime       @default(now())
  academicSession    AcademicSession  @relation(fields: [academicSessionId], references: [id])
  attendances   Attendance[]
  teacher       Staff?         @relation("ClassTeacher", fields: [teacherId], references: [id])
  exams         Exam[]
  feeStructures FeeStructure[]
  students      Student[]
  subjects      Subject[]
  dateSheet     ExamDateSheet[]
  homeworks     Homework[]
  studyMaterials StudyMaterial[]
  timetables    Timetable[]

  @@index([teacherId])
  @@index([grade, section])
}

model Subject {
  id           String       @id @default(cuid())
  name         String
  code         String       @unique
  classId      String?
  teacherId    String?
  maxMarks     Float?
  passingMarks Float?
  type         SubjectType?
  results      Result[]
  class        Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher      Staff?       @relation(fields: [teacherId], references: [id])
  dateSheet    ExamDateSheet[]
  homeworks    Homework[]
  studyMaterials StudyMaterial[]
  timetables   Timetable[]

  @@index([classId])
  @@index([teacherId])
}

model Staff {
  id            String          @id @default(cuid())
  userId        String          @unique
  staffId       String?
  designation   String
  department    String?
  qualification String?
  experience    String?
  salary        Float?
  joinDate      DateTime        @default(now())
  active        Boolean         @default(true)
  profileImg    String?
  gender        Gender?
  dob           DateTime?
  address       String?
  phone         String?
  Attendance    Attendance[]
  classes       Class[]         @relation("ClassTeacher")
  leaves        Leave[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects      Subject[]
  staffAttendance StaffAttendance[]
  documents     StaffDocument[]
  homework      Homework[]
  studyMaterials StudyMaterial[]
  timetables    Timetable[]
  certificates  Certificate[]
  idCards       IDCard[]

  @@index([userId])
  @@index([designation])
  @@index([staffId])
}

model StaffDocument {
  id        String   @id @default(cuid())
  staffId   String
  type      String
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model StaffAttendance {
  id        String           @id @default(cuid())
  staffId   String
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([staffId, date])
}

model Student {
  id            String         @id @default(cuid())
  userId        String         @unique
  admissionNo   String         @unique
  rollNumber    String
  admissionDate DateTime       @default(now())
  dob           DateTime?
  gender        Gender?
  bloodGroup    String?
  address       String?
  permanentAddress String?
  classId       String?
  active        Boolean        @default(true)
  profileImg    String?
  fatherName    String?
  fatherPhone   String?
  fatherOccupation String?
  motherName    String?
  motherPhone   String?
  motherOccupation String?
  guardianName  String?
  guardianPhone String?
  occupation    String         @default("")
  religion      String         @default("")
  caste         String         @default("")
  category      String?
  udiseCode     String?        @unique
  contactNo     String?
  previousSchool String?
  remarks       String?
  usesTransport Boolean        @default(false)
  attendance    Attendance[]
  fees          FeePayment[]
  results       Result[]
  transport     TransportAssignment[]
  class         Class?         @relation(fields: [classId], references: [id])
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications Notification[] @relation("NotificationToStudent")
  documents     StudentDocument[]
  homeworkSubmissions HomeworkSubmission[]
  certificates  Certificate[]
  idCards       IDCard[]

  @@unique([classId, rollNumber])
  @@index([classId])
  @@index([active])
}

model StudentDocument {
  id        String   @id @default(cuid())
  studentId String
  type      String
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model TransportAssignment {
  id        String   @id @default(cuid())
  studentId String   @unique
  routeName String?
  stopName  String?
  busNumber String?
  driverName String?
  driverPhone String?
  feeAmount Decimal? @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([isActive])
}

model Attendance {
  id         String           @id @default(cuid())
  classId    String
  studentId  String
  date       DateTime
  status     AttendanceStatus
  markedById String
  createdAt  DateTime         @default(now())
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedBy   Staff            @relation(fields: [markedById], references: [id])
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([classId, date])
  @@index([markedById])
}

model FeeCategory {
  id        String   @id @default(cuid())
  name      String
  description String?
  createdAt DateTime @default(now())
  structures FeeStructure[]

  @@index([name])
}

model FeeStructure {
  id           String       @id @default(cuid())
  classId      String
  categoryId   String?
  name         String?
  amount       Decimal      @default(0) @db.Decimal(12, 2)
  tuitionFee   Decimal?     @db.Decimal(12, 2)
  examFee      Decimal?     @db.Decimal(12, 2)
  transportFee Decimal?     @db.Decimal(12, 2)
  miscFee      Decimal?     @db.Decimal(12, 2)
  total        Decimal      @default(0) @db.Decimal(12, 2)
  monthlyFee   Decimal?     @db.Decimal(12, 2)
  totalMonths  Int          @default(12)
  isOptional   Boolean      @default(false)
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  payments     FeePayment[]
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  category     FeeCategory? @relation(fields: [categoryId], references: [id])

  @@index([classId])
  @@index([categoryId])
}

model FeePayment {
  id                String       @id @default(cuid())
  studentId         String
  feeStructureId    String
  amountPaid        Decimal      @db.Decimal(12, 2)
  remainAmount      Decimal      @db.Decimal(12, 2)
  status            FeeStatus    @default(PENDING)
  paymentDate       DateTime?
  paymentMode       PaymentMethod?
  discount          Decimal?     @db.Decimal(12, 2)
  lateFine          Decimal?     @db.Decimal(12, 2)
  receiptNo         String?
  remarks           String?
  razorpayOrder     String?      @unique
  razorpayPaymentId String?
  receiptUrl        String?
  createdAt         DateTime     @default(now())
  feeStructure      FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([feeStructureId])
  @@index([receiptNo])
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  name      String
  description String?
  createdAt DateTime @default(now())
  expenses  Expense[]

  @@index([name])
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  categoryId  String?
  paidTo      String?
  paymentMode PaymentMethod?
  billUrl     String?
  createdById String
  transaction TransactionType
  createdBy   User            @relation(fields: [createdById], references: [id])
  category    ExpenseCategory? @relation(fields: [categoryId], references: [id])

  @@index([createdById])
  @@index([categoryId])
  @@index([date])
}

model Exam {
  id          String        @id @default(cuid())
  name        String
  category    ExamCategory
  sequence    Int?
  classId     String
  startDate   DateTime
  endDate     DateTime
  isLocked    Boolean       @default(false)
  description String?
  instructions String?
  createdById String
  createdAt   DateTime      @default(now())

  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("ExamCreatedBy", fields: [createdById], references: [id])
  results     Result[]
  dateSheet   ExamDateSheet[]

  @@index([classId])
  @@index([category])
  @@unique([classId, category, sequence])
}

model ExamDateSheet {
  id        String   @id @default(cuid())
  examId    String
  classId   String
  subjectId String
  examDate  DateTime
  startTime DateTime
  endTime   DateTime
  room      String?

  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([classId])
  @@index([subjectId])
  @@unique([examId, subjectId, classId])
}

model Result {
  id         String   @id @default(cuid())
  studentId  String
  examId     String
  subjectId  String
  marks      Float
  maxMarks   Float
  grade      String?
  rank       Int?
  remarks    String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploader   User?    @relation(fields: [uploadedBy], references: [id])

  @@unique([studentId, examId, subjectId])
  @@index([studentId])
  @@index([examId])
  @@index([subjectId])
}

model Timetable {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String?
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?
  createdAt DateTime @default(now())

  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Staff?   @relation(fields: [teacherId], references: [id])

  @@index([classId, dayOfWeek])
  @@index([teacherId])
}

model Homework {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String
  title       String
  description String?
  dueDate     DateTime
  attachment  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     Staff    @relation(fields: [teacherId], references: [id])
  submissions HomeworkSubmission[]

  @@index([classId])
  @@index([teacherId])
}

model HomeworkSubmission {
  id         String   @id @default(cuid())
  homeworkId String
  studentId  String
  answerFile String?
  remarks    String?
  status     SubmissionStatus @default(PENDING)
  submittedAt DateTime @default(now())
  gradedAt   DateTime?
  teacherRemarks String?

  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
  @@index([studentId])
}

model StudyMaterial {
  id          String   @id @default(cuid())
  classId     String
  subjectId   String
  teacherId   String
  title       String
  description String?
  fileUrl     String?
  videoLink   String?
  type        MaterialType
  createdAt   DateTime @default(now())

  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     Staff    @relation(fields: [teacherId], references: [id])

  @@index([classId, subjectId])
  @@index([teacherId])
}

model Announcement {
  id           String                   @id @default(cuid())
  title        String
  content      String
  attachment   String?
  expiryDate   DateTime?
  isPinned     Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  createdBy    String
  creator      User                     @relation(fields: [createdBy], references: [id])
  visibleRoles AnnouncementVisibility[]
}

model AnnouncementVisibility {
  id             String       @id @default(cuid())
  announcementId String
  role           Role
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, role])
  @@index([announcementId])
}

model Certificate {
  id             String   @id @default(cuid())
  certificateNo  String   @unique
  type           CertificateType
  studentId      String?
  staffId        String?
  issueDate      DateTime @default(now())
  content        Json?
  remarks        String?
  createdAt      DateTime @default(now())

  student        Student? @relation(fields: [studentId], references: [id])
  staff          Staff?   @relation(fields: [staffId], references: [id])

  @@index([type])
  @@index([studentId])
  @@index([staffId])
}

model IDCard {
  id        String   @id @default(cuid())
  studentId String?  @unique
  staffId   String?  @unique
  cardNo    String   @unique
  issueDate DateTime @default(now())
  expiryDate DateTime?
  qrData    String?
  createdAt DateTime @default(now())

  student   Student? @relation(fields: [studentId], references: [id])
  staff     Staff?   @relation(fields: [staffId], references: [id])

  @@index([cardNo])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  Student   Student[]        @relation("NotificationToStudent")

  @@index([userId])
  @@index([type])
}

model Leave {
  id        String   @id @default(cuid())
  staffId   String
  fromDate  DateTime
  toDate    DateTime
  reason    String
  createdAt DateTime @default(now())
  status    String   @default("PENDING")
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ========== ENUMS ==========

enum Role {
  ADMIN
  STAFF
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum NotificationType {
  ANNOUNCEMENT
  FEE_REMINDER
  RESULT_PUBLISHED
  ATTENDANCE_ALERT
  GENERAL
  HOMEWORK
  CERTIFICATE
}

enum Grade {
  NURSERY
  LKG
  UKG
  ONE
  TWO
  THREE
  FOUR
  FIVE
  SIX
  SEVEN
  EIGHT
  NINE
  TEN
}

enum PaymentMethod {
  CASH
  ONLINE
  CARD
  UPI
  BANK
  CHEQUE
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
}

enum ExamCategory {
  UNIT_TEST
  MONTHLY_TEST
  HALF_YEARLY
  ANNUAL
  PRE_BOARD
  PRACTICAL
}

enum SubjectType {
  THEORY
  PRACTICAL
  BOTH
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
}

enum MaterialType {
  NOTES
  PDF
  VIDEO
  REFERENCE
  ASSIGNMENT
}

enum CertificateType {
  BONAFIDE
  CHARACTER
  TRANSFER
  STUDY
  FEE_CLEARANCE
  NO_DUES
  ACHIEVEMENT
  PARTICIPATION
  EXPERIENCE
  JOINING_LETTER
}
